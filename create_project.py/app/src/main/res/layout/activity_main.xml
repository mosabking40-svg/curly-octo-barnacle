<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TikTok Auto Scroller"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. تفعيل التمرير التلقائي"
        android:textSize="16sp"
        android:backgroundTint="#00F2FE"
        android:textColor="#000000"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_touch_blocker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. تشغيل وضع الجيب (شاشة سوداء)"
        android:textSize="16sp"
        android:backgroundTint="#FE2C55"
        android:textColor="#FFFFFF"
        android:padding="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="طريقة الاستخدام: فعّل التمرير أولاً، ثم اذهب للتيك توك، وعند وضع الهاتف في جيبك اضغط على إشعار وضع الجيب."
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="40dp"/>

</LinearLayout>